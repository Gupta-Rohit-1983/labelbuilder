<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
  Main window shell (Phase 3b).
  top:    menu bar + toolbar
  center: designer workspace placeholder — docking (Phase 5) then canvas (Phase 6)
  bottom: sectioned status bar

  Menus/toolbar carry placeholder handlers here; Phase 4 rebuilds them from a central
  ActionRegistry (ribbon + menus + shortcuts sharing one command definition).
-->
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.rohit.labelbuilder.desktop.shell.MainWindowController"
            stylesheets="@/css/shell.css">
  <top>
    <VBox>
      <MenuBar>
        <menus>
          <Menu text="_File">
            <items>
              <MenuItem text="New Label…" onAction="#onNew" accelerator="Shortcut+N"/>
              <MenuItem text="Open…" onAction="#onOpen" accelerator="Shortcut+O"/>
              <SeparatorMenuItem/>
              <MenuItem text="Save" onAction="#onSave" accelerator="Shortcut+S"/>
              <MenuItem text="Save As…" onAction="#onSaveAs" accelerator="Shortcut+Shift+S"/>
              <SeparatorMenuItem/>
              <MenuItem text="Exit" onAction="#onExit"/>
            </items>
          </Menu>
          <!-- Edit/View accelerators deliberately deferred to Phase 4's ActionRegistry: scene-wide
               Ctrl+X/C/V bindings here would shadow TextInputControl's built-in clipboard handling
               the moment the first text field appears. -->
          <Menu text="_Edit">
            <items>
              <MenuItem text="Undo" onAction="#onNotImplemented"/>
              <MenuItem text="Redo" onAction="#onNotImplemented"/>
              <SeparatorMenuItem/>
              <MenuItem text="Cut" onAction="#onNotImplemented"/>
              <MenuItem text="Copy" onAction="#onNotImplemented"/>
              <MenuItem text="Paste" onAction="#onNotImplemented"/>
            </items>
          </Menu>
          <Menu text="_View">
            <items>
              <MenuItem text="Zoom In" onAction="#onNotImplemented"/>
              <MenuItem text="Zoom Out" onAction="#onNotImplemented"/>
              <MenuItem text="Fit to Window" onAction="#onNotImplemented"/>
            </items>
          </Menu>
          <Menu text="_Help">
            <items>
              <MenuItem text="About LabelBuilder" onAction="#onAbout"/>
            </items>
          </Menu>
        </menus>
      </MenuBar>

      <ToolBar>
        <items>
          <Button text="New" onAction="#onNew"/>
          <Button text="Open" onAction="#onOpen"/>
          <Button text="Save" onAction="#onSave"/>
          <Separator/>
          <Button text="Print" onAction="#onNotImplemented"/>
        </items>
      </ToolBar>
    </VBox>
  </top>

  <center>
    <!-- The docking framework (Phase 5) replaces this StackPane's content; the pane itself marks
         the docking area's bounds in the shell. -->
    <StackPane styleClass="docking-area">
      <Label fx:id="centerPlaceholder" styleClass="workspace-placeholder"/>
    </StackPane>
  </center>

  <bottom>
    <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="8">
      <padding>
        <Insets top="3" right="10" bottom="3" left="10"/>
      </padding>
      <Label fx:id="statusMessage" styleClass="status-message"/>
      <Region HBox.hgrow="ALWAYS"/>
      <Label fx:id="cursorPositionLabel" styleClass="status-section"/>
      <Separator orientation="VERTICAL"/>
      <Label fx:id="zoomLabel" styleClass="status-section"/>
      <Separator orientation="VERTICAL"/>
      <Label fx:id="environmentLabel" styleClass="status-section"/>
    </HBox>
  </bottom>
</BorderPane>
