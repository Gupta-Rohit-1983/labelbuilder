<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
  Main window shell — LAYOUT ONLY.
  Menus and toolbar are deliberately empty here: the controller populates them from the
  ActionRegistry (Phase 4a), so no onAction/accelerator wiring may ever appear in this file
  (enforced by MainWindowFxmlTest).

  top:    menu row (menu bar + quick-access toolbar) + ribbon (registry-generated; the
          controller populates both and appends the ribbon to topBox)
  center: docking area — docking framework (Phase 5) then canvas (Phase 6)
  bottom: sectioned status bar
-->
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.rohit.labelbuilder.desktop.shell.MainWindowController"
            stylesheets="@/css/shell.css">
  <top>
    <VBox fx:id="topBox">
      <HBox styleClass="menu-row" alignment="CENTER_LEFT">
        <MenuBar fx:id="menuBar"/>
        <Region HBox.hgrow="ALWAYS"/>
        <HBox fx:id="quickAccessBar" styleClass="quick-access-bar" alignment="CENTER_RIGHT"/>
      </HBox>
    </VBox>
  </top>

  <center>
    <!-- The controller renders the DockLayout into this host (Phase 5a); the placeholder label
         is handed to the layout's Center slot until the canvas arrives (Phase 6). -->
    <StackPane fx:id="dockingArea" styleClass="docking-area">
      <Label fx:id="centerPlaceholder" styleClass="workspace-placeholder"/>
    </StackPane>
  </center>

  <bottom>
    <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="8">
      <padding>
        <Insets top="3" right="10" bottom="3" left="10"/>
      </padding>
      <Label fx:id="statusMessage" styleClass="status-message"/>
      <Region HBox.hgrow="ALWAYS"/>
      <Label fx:id="cursorPositionLabel" styleClass="status-section"/>
      <Separator orientation="VERTICAL"/>
      <Label fx:id="zoomLabel" styleClass="status-section"/>
      <Separator orientation="VERTICAL"/>
      <Label fx:id="environmentLabel" styleClass="status-section"/>
    </HBox>
  </bottom>
</BorderPane>
