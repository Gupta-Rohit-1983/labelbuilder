<?xml version="1.0" encoding="UTF-8"?>
<!--
  Desktop logging configuration.

  Log directory comes from the 'labelbuilder.log-dir' system property set in
  LabelBuilderApp.main() before the Spring context starts. A fallback keeps logging working when
  the app is launched some other way (e.g. an IDE run of a test) without that property.
-->
<configuration>
  <property name="LOG_DIR" value="${labelbuilder.log-dir:-${java.io.tmpdir}/labelbuilder-logs}"/>
  <property name="PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n"/>

  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>${PATTERN}</pattern>
    </encoder>
  </appender>

  <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${LOG_DIR}/labelbuilder.log</file>
    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
      <fileNamePattern>${LOG_DIR}/labelbuilder.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
      <maxFileSize>10MB</maxFileSize>
      <maxHistory>14</maxHistory>
      <totalSizeCap>200MB</totalSizeCap>
    </rollingPolicy>
    <encoder>
      <pattern>${PATTERN}</pattern>
    </encoder>
  </appender>

  <root level="INFO">
    <appender-ref ref="CONSOLE"/>
    <appender-ref ref="FILE"/>
  </root>

  <logger name="com.rohit.labelbuilder" level="DEBUG"/>
</configuration>
